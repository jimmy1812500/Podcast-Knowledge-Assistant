# Redis — used by Celery as broker and result backend
REDIS_URL=redis://localhost:6379/0

# ChromaDB — override when running via Docker Compose
CHROMA_HOST=localhost
CHROMA_PORT=8001

# HuggingFace token — required only when diarize=True
HF_TOKEN=

# Ollama model for synthesis (must be pulled locally)
OLLAMA_MODEL=llama3
