# Required for pyannote speaker diarization.
# 1. Accept license at https://huggingface.co/pyannote/speaker-diarization-3.1
# 2. Generate token at https://huggingface.co/settings/tokens
# Leave blank to skip diarization (speaker metadata will be "UNKNOWN").
HF_TOKEN=hf_...

# ChromaDB server (used when running with Docker Compose)
# Falls back to ./chroma_data on disk when unreachable
CHROMA_HOST=localhost
CHROMA_PORT=8001
